# --- F5AI (LLM aggregator) https://f5ai.ru/api ---
F5AI_API_KEY=
F5AI_BASE_URL=https://api.f5ai.ru
F5AI_MODEL=gpt-4o
# F5AI_TIMEOUT_MS=120000

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
# Optional allowlist of Telegram user ids (comma-separated). Empty = allow all.
# TELEGRAM_ALLOW_FROM=123456789

# --- Existing PostgreSQL (amoCRM mirror). Does not create/start a database. ---
AMOCRM_DB_HOST=127.0.0.1
AMOCRM_DB_PORT=5432
AMOCRM_DB_NAME=amocrm
AMOCRM_DB_USER=readonly_user
AMOCRM_DB_PASSWORD=
AMOCRM_DB_SSLMODE=prefer

# Optional hardening overrides
# AMOCRM_DB_STATEMENT_TIMEOUT_MS=10000
# AMOCRM_DB_MAX_ROWS=100
# AMOCRM_DB_DEFAULT_ROWS=10
# AMOCRM_DB_MAX_RESULT_BYTES=102400
# AMOCRM_DB_MAX_SQL_LENGTH=10000
# AMOCRM_DB_SCHEMA=public
