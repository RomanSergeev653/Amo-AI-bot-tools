{
  "name": "openclaw-amocrm-readonly-sql",
  "version": "0.2.0",
  "description": "OpenClaw tool plugin: safe read-only SQL queries against an existing amoCRM PostgreSQL database",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "Docs/generated",
    ".env.example",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "plugin:build": "npm run build && openclaw plugins build --entry ./dist/index.js",
    "plugin:validate": "npm run plugin:build && openclaw plugins validate --entry ./dist/index.js",
    "check-connection": "tsx scripts/check-connection.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "pg": "^8.16.0",
    "typebox": "^1.0.34"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.17"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=20"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
